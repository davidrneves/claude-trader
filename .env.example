# Alpaca API (get keys from https://app.alpaca.markets/paper/dashboard/overview)
ALPACA_API_KEY=your_api_key_here
ALPACA_SECRET_KEY=your_secret_key_here
ALPACA_PAPER_TRADE=true

# Gemini API (for multi-agent analysis)
GEMINI_API_KEY=your_gemini_key_here

# Telegram notifications (optional - get token from @BotFather)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Risk Parameters (defaults are safe)
# MAX_POSITION_PCT=0.02
# STOP_LOSS_PCT=0.08
# TRAILING_STOP_PCT=0.05
# MAX_DAILY_LOSS_PCT=0.03
# MAX_DRAWDOWN_PCT=0.10
# MAX_CONSECUTIVE_LOSSES=3
# MAX_OPEN_POSITIONS=5

# Strategy
# WATCHLIST=["AAPL","MSFT","GOOGL","AMZN","NVDA","META","TSLA","SPY","QQQ","AMD"]
# EMA_PERIOD=20
